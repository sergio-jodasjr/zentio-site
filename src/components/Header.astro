---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const WA = "https://wa.me/5511940875900";
---

<header>
  <nav class="container">
    <h2 class="brand"><a href="/">{SITE_TITLE}</a></h2>

    <div class="internal-links">
      <HeaderLink href="/">Início</HeaderLink>
      <HeaderLink href="/solucoes">Soluções</HeaderLink>
      <HeaderLink href="/casos-de-uso">Casos de uso</HeaderLink>
      <HeaderLink href="/como-funciona">Como funciona</HeaderLink>
      <HeaderLink href="/insights">Insights</HeaderLink>
      <HeaderLink href="/sobre">Sobre</HeaderLink>
      <HeaderLink href="/contato">Contato</HeaderLink>
      <a class="lang" href="/en/">EN</a>
    </div>

    <div class="actions">
      <a class="btn btn-ghost" href={WA} target="_blank" rel="noreferrer">WhatsApp</a>
      <a class="btn btn-primary" href="/contato">Solicitar contato</a>
    </div>
  </nav>
</header>

<style>
  header{
    margin:0;
    padding:0;
    background:#fff;
    border-bottom:1px solid rgba(43,47,54,.12);
    position:sticky;
    top:0;
    z-index:50;
  }
  .container{
    max-width:1120px;
    margin:0 auto;
    padding:14px 20px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:16px;
    flex-wrap:wrap;
  }
  .brand{margin:0;font-size:18px;font-weight:900;letter-spacing:.2px}
  .brand a{text-decoration:none}
  .internal-links{
    display:flex;
    align-items:center;
    gap:10px;
    flex-wrap:wrap;
  }
  .internal-links :global(a){
    padding:8px 10px;
    text-decoration:none;
    color:#2B2F36;
    font-weight:700;
    font-size:14px;
    border-radius:10px;
  }
  .internal-links :global(a.active){
    background:rgba(123,63,228,.10);
    color:#7B3FE4;
  }
  .lang{
    border:1px solid rgba(43,47,54,.12);
    color:#6B7280 !important;
    font-weight:800;
  }
  .actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:10px 14px;
    border-radius:12px;
    border:1px solid rgba(43,47,54,.12);
    font-weight:800;
    text-decoration:none;
  }
  .btn-primary{background:#7B3FE4;color:#fff;border-color:transparent}
  .btn-ghost{background:#fff;color:#2B2F36}
</style>