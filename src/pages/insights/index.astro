---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<SiteLayout title="Insights | Zentio" lang="pt">
  <h1>Insights</h1>
  <p>Conteúdos sobre automação, integrações e SaaS B2B.</p>

  <ul>
    {posts.map((p) => (
      <li style="margin:14px 0">
        <a href={"/insights/" + p.slug} style="font-weight:900;color:var(--text)">{p.data.title}</a>
        <div style="color:var(--muted);font-size:14px">{p.data.description}</div>
      </li>
    ))}
  </ul>
</SiteLayout>
